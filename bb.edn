{:paths ["src" "test"]
 :bbin/bin {aishell {:main-opts ["-m" "aishell.core"]}}
 :tasks {test {:doc "Run all clojure.test tests under test/"
               :requires ([run-tests])
               :task (let [{:keys [fail error]} (run-tests/run-all)]
                       (System/exit (if (zero? (+ (or fail 0) (or error 0))) 0 1)))}}}
